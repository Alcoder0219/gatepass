# Docker Compose config — copy to `.env` before `docker compose up`.
# `.env` is gitignored. NEVER put real credentials in THIS file; it IS committed.

# The public URL users browse to. Drives CORS and email deep links.
CLIENT_URL=https://gatepass.example.com

# MongoDB Atlas connection string.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/gatepass?retryWrites=true&w=majority

# Generate each with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=<a long random string>
JWT_REFRESH_SECRET=<a different long random string>

# The single super admin created by `npm run seed:prod` on a fresh database.
SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=<a strong password>
SUPERADMIN_EMPLOYEE_ID=EMP0001SA

# Same-origin: nginx serves the SPA and proxies /api to the API container.
VITE_API_URL=/api/v1

# The expiry sweep runs in-process — keep true on exactly ONE API replica.
JOBS_ENABLED=true

# Real SMTP. Leave SMTP_HOST blank and emails are logged instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Amsons Group <no-reply@amsongroup.com>
