# ─── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:5173

# ─── Database ──────────────────────────────────────────────────────────────
# NEVER put real credentials in this file — it is committed to git.
# Put the real URI in `.env` (gitignored). Local: mongodb://127.0.0.1:27017/gatepass
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/gatepass?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN_REMEMBER=30d

# ─── Uploads ───────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ─── Mail (Nodemailer) ─────────────────────────────────────────────────────
# Leave SMTP_HOST empty to log emails to console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="GatePass Pro <no-reply@gatepasspro.io>"

# ─── Security ──────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10
OTP_EXPIRY_MINUTES=10
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=500

# ─── Seed ──────────────────────────────────────────────────────────────────
# Only used by the DEMO seeder (`npm run seed`). Never run that in production —
# it creates 20 accounts that all share this password. Use `npm run seed:prod`.
SEED_DEFAULT_PASSWORD=Passw0rd@123

# ─── Production bootstrap (`npm run seed:prod`) ────────────────────────────
# The single super admin created on a fresh production database.
SUPERADMIN_NAME=Bhanu Partap
SUPERADMIN_EMAIL=bhanupartap@amsongroup.com
SUPERADMIN_PASSWORD=
SUPERADMIN_EMPLOYEE_ID=EMP0001SA

# Set to false on every API replica but one (the expiry sweep is in-process).
JOBS_ENABLED=true
